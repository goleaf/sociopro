{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "anandsiddharth/laravel-paytm-wallet": "^2.0",
        "firebase/php-jwt": "^7.1",
        "flutterwavedev/flutterwave-v3": "^1.0",
        "intervention/image": "^2.7",
        "jorenvanhocht/laravel-share": "^4.2",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.12",
        "php-flasher/flasher-laravel": "^2.6",
        "razorpay/razorpay": "^2.8",
        "stripe/stripe-php": "^10.11",
        "yajra/laravel-datatables-oracle": "^13.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/CommonHelper.php",
            "app/Helpers/ApiHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "@php artisan test",
        "test:unit": "@php artisan test --testsuite=Unit",
        "test:feature": "@php artisan test --testsuite=Feature",
        "test:migrations": "@php artisan test tests/Feature/MigrationSafetyAuditTest.php",
        "pint": "vendor/bin/pint",
        "pint:test": "vendor/bin/pint --test",
        "format": "@pint",
        "format:test": "@pint:test",
        "analyse": "@php -r \"if (file_exists('vendor/bin/phpstan')) { passthru('vendor/bin/phpstan analyse --memory-limit=1G', $code); exit($code); } fwrite(STDERR, 'PHPStan is not installed; skipping analyse.'.PHP_EOL);\"",
        "rector:dry": "@php -r \"if (file_exists('vendor/bin/rector')) { passthru('vendor/bin/rector --dry-run', $code); exit($code); } fwrite(STDERR, 'Rector is not installed; skipping rector:dry.'.PHP_EOL);\"",
        "rector": "@php -r \"if (file_exists('vendor/bin/rector')) { passthru('vendor/bin/rector', $code); exit($code); } fwrite(STDERR, 'Rector is not installed; skipping rector.'.PHP_EOL);\"",
        "quality:artisan": [
            "@php artisan config:cache",
            "@php artisan config:clear",
            "@php artisan route:cache",
            "@php artisan route:clear",
            "@php artisan view:cache",
            "@php artisan view:clear",
            "@php artisan optimize:clear"
        ],
        "quality:cache": "@quality:artisan",
        "quality:php": [
            "@format:test",
            "@analyse"
        ],
        "quality:tests": [
            "@test:unit",
            "@test:feature",
            "@test:migrations"
        ],
        "quality:frontend": [
            "npm run lint",
            "npm run stylelint",
            "npm run format:check",
            "npm run audit:prod",
            "npm run build"
        ],
        "quality": [
            "@quality:php",
            "@quality:tests",
            "@quality:frontend",
            "@quality:artisan"
        ],
        "ci": [
            "@composer validate --strict --no-interaction",
            "@composer audit --no-interaction",
            "@quality"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
