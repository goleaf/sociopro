{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "build": "npm run production",
        "lint": "eslint \"resources/js/**/*.js\"",
        "lint:fix": "eslint \"resources/js/**/*.js\" --fix",
        "format": "prettier --write \"resources/**/*.{js,css}\"",
        "format:check": "prettier --check \"resources/**/*.{js,css}\"",
        "stylelint": "stylelint \"resources/css/**/*.css\"",
        "audit:prod": "npm audit --omit=dev --audit-level=moderate",
        "quality": "npm run lint && npm run stylelint && npm run format:check && npm run audit:prod && npm run build"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.4.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.18.1",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "laravel-mix": "^6.0.6",
        "lodash": "^4.17.19",
        "postcss": "^8.4.6",
        "postcss-import": "^14.0.2",
        "prettier": "^3.9.4",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^36.0.1",
        "tailwindcss": "^3.0.18",
        "webpack": "^5.104.1"
    },
    "dependencies": {
        "codex": "^0.2.3",
        "moment-timezone": "^0.5.37",
        "sweetalert2": "^11.4.31"
    }
}
