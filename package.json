{
    "private": true,
    "scripts": {
        "dev": "vite",
        "development": "npm run dev",
        "watch": "npm run dev",
        "watch-poll": "CHOKIDAR_USEPOLLING=true vite",
        "hot": "npm run dev",
        "prod": "npm run build",
        "production": "npm run build",
        "build": "vite build",
        "lint": "eslint \"resources/js/**/*.js\"",
        "lint:fix": "eslint \"resources/js/**/*.js\" --fix",
        "format": "prettier --write \"resources/**/*.{js,scss}\"",
        "format:check": "prettier --check \"resources/**/*.{js,scss}\"",
        "stylelint": "stylelint \"resources/scss/**/*.scss\"",
        "audit:prod": "npm audit --omit=dev --audit-level=moderate",
        "quality": "npm run lint && npm run stylelint && npm run format:check && npm run audit:prod && npm run build",
        "agent:hooks:smoke": "node scripts/agent-hooks/smoke.mjs"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.18.1",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "laravel-vite-plugin": "^3.1.0",
        "lodash": "^4.17.19",
        "postcss": "^8.4.6",
        "postcss-import": "^14.0.2",
        "prettier": "^3.9.4",
        "sass": "^1.101.0",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^36.0.1",
        "tailwindcss": "^3.0.18",
        "vite": "^8.1.3"
    },
    "dependencies": {
        "moment-timezone": "^0.5.37",
        "sweetalert2": "^11.4.31"
    }
}
