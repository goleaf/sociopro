APP_NAME=Sociopro
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
# SESSION_CONNECTION=
# SESSION_STORE=
SESSION_COOKIE=sociopro_session
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_DOMAIN=
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Set SESSION_SECURE_COOKIE=true in production so session cookies are only sent over HTTPS.
SESSION_SECURE_COOKIE=false
BCRYPT_ROUNDS=12

# Comma-separated allowlist of browser origins permitted to call the API.
# Leave as "*" for a public token API; lock down in production.
CORS_ALLOWED_ORIGINS=*
SANCTUM_EXPIRATION=43200
API_IDEMPOTENCY_TTL_MINUTES=1440
API_IDEMPOTENCY_LOCK_SECONDS=10
API_IDEMPOTENCY_WAIT_SECONDS=3

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_LOG_CHANNEL=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
